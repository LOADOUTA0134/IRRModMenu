<Window x:Class="IncursionItemSpawner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Incursion Menu" Height="300" Width="400">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="CHOOSE FUNCTION" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <ui:Button Content="ITEM CHEAT" Icon="Box24" Width="200" Height="50" Click="OpenItemSpawner_Click"/>
        <ui:Button Content="LOADOUT DESIGNER" Icon="Shield24" Width="200" Height="50" Click="OpenLoadout_Click"/>
        <ui:Button Content="FACTIONS" Icon="People24" Width="200" Height="50" Click="OpenFactions_Click"/>
    </StackPanel>
</Window>