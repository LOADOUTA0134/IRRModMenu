<Window x:Class="IncursionItemSpawner.FactionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Faction Manager" Height="400" Width="600"
        Background="Transparent" WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="FACTION REPUTATION" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>

            <ui:Card Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="VLF" VerticalAlignment="Center" FontSize="16"/>
                    <TextBlock x:Name="VLFLevelText" Grid.Column="1" VerticalAlignment="Center" FontSize="16" Margin="10,0"/>
                    <Slider x:Name="VLFLevel" Grid.Column="2" Value="1" Minimum="1" Maximum="4" TickFrequency="1" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Width="150" Margin="10,0" ValueChanged="VLFLevel_ValueChanged" />
                    <ui:Button Grid.Column="3" Content="SET LEVEL" Click="SetFaction_Click" Tag="VLF" Appearance="Primary"/>
                </Grid>
            </ui:Card>

            <ui:Card Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="UICS" VerticalAlignment="Center" FontSize="16"/>
                    <TextBlock x:Name="UICSLevelText" Grid.Column="1" VerticalAlignment="Center" FontSize="16" Margin="10,0"/>
                    <Slider x:Name="UICSLevel" Grid.Column="2" Value="1" Minimum="1" Maximum="4" TickFrequency="1" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Width="150" Margin="10,0" ValueChanged="UICSLevel_ValueChanged"/>
                    <ui:Button Grid.Column="3" Content="SET LEVEL" Click="SetFaction_Click" Tag="UICS" Appearance="Primary"/>
                </Grid>
            </ui:Card>

            <ui:Card Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="IGC" VerticalAlignment="Center" FontSize="16"/>
                    <TextBlock x:Name="IGCLevelText" Grid.Column="1" Text="Level 1" VerticalAlignment="Center" FontSize="16" Margin="10,0"/>
                    <Slider x:Name="IGCLevel" Grid.Column="2" Value="1" Minimum="1" Maximum="4" TickFrequency="1" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Width="150" Margin="10,0" ValueChanged="IGCLevel_ValueChanged"/>
                    <ui:Button Grid.Column="3" Content="SET LEVEL" Click="SetFaction_Click" Tag="IGC" Appearance="Primary"/>
                </Grid>
            </ui:Card>
        </StackPanel>
    </Grid>
</Window>